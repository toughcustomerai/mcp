# ─── Mode ─────────────────────────────────────────────────────────────────
# 'live' (default) requires Supabase + Salesforce. 'mock' uses in-memory
# data and skips all auth — local-dev / smoke-test only.
TC_MODE=live

# ─── Supabase (auto-injected by the Vercel Marketplace integration) ───────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Public URLs ──────────────────────────────────────────────────────────
# Where this MCP server is reachable. Falls back to VERCEL_PROJECT_PRODUCTION_URL.
MCP_PUBLIC_URL=https://mcp.toughcustomer.ai
# Where the /connect UI lives. Same Vercel project; alias domain.
APP_BASE_URL=https://app.toughcustomer.ai
# Supabase Auth (custom hostname). Advertised in /.well-known/oauth-protected-resource.
AUTH_BASE_URL=https://auth.toughcustomer.ai

# ─── Salesforce Connected App ────────────────────────────────────────────
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
# Optional with PKCE; required if the Connected App enforces "Require Secret".
SF_CLIENT_SECRET=
SF_API_VERSION=v62.0

# ─── Vault (v1) ──────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
# Graduate to Supabase Vault / KMS before any external customer onboards.
# See docs/VAULT_V2.md.
VAULT_KEY_V1=

# ─── Optional: domain allow-list ─────────────────────────────────────────
# Comma-separated email domains. Unset = open. userstories.md §2.4.
MCP_ALLOWED_DOMAINS=
